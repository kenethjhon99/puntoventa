# ---------------------------------------------------------------
# Variables de entorno backend (plantilla).
#
# Copia este archivo a `.env` y rellena con valores REALES.
# `.env` esta en .gitignore: nunca lo commitees.
# ---------------------------------------------------------------

# Puerto donde escucha el API.
PORT=3000

# Conexion a Postgres.
PGHOST=localhost
PGPORT=5432
PGDATABASE=database2
PGUSER=postgres
# En produccion: NUNCA dejar passwords debiles como 1234 o postgres.
# Usa minimo 16 caracteres mezclando mayusculas, minusculas, numeros y simbolos.
PGPASSWORD=cambia_este_password

# Secret para firmar JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Minimo 32 bytes de entropia.
JWT_SECRET=genera_un_secret_aleatorio_de_32_bytes_o_mas

# Tiempo de vida del JWT. Formatos validos: '8h', '15m', '7d'.
JWT_EXPIRES=8h

# Opcional: rounds de bcrypt para hash de passwords.
# Default 10. Clampado al rango [10, 14] por validateEnv.
# BCRYPT_ROUNDS=10

# Opcional: ambiente. "production" activa validaciones estrictas
# (rechaza JWT_SECRET corto, passwords debiles, requests CORS sin Origin,
# y devuelve mensajes de error genericos al cliente).
# NODE_ENV=production

# Opcional: hops de proxy en los que confiar para X-Forwarded-For.
# Necesario si la API esta detras de nginx, Cloudflare, Vercel, etc.
# Sin esto el rate-limiter ve a todos los clientes con la misma IP.
# Valores tipicos: "1" (un proxy), "true" (cualquier proxy, menos seguro),
# o una IP especifica.
# TRUST_PROXY=1

# Opcional: en CORS, permitir orgenes *.vercel.app (previews).
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Opcional: origenes adicionales permitidos por CORS, separados por coma.
# FRONTEND_URL=https://app.midominio.com
# CORS_ORIGINS=https://otro.midominio.com,https://staging.midominio.com
